# ALIVE Frontend Environment Variables

# API Backend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# Contract Addresses (mock addresses for development)
# In production, replace with actual deployed addresses
NEXT_PUBLIC_FACTORY_ADDRESS=0xALIVE0000000000000000000000000FACTORY001
NEXT_PUBLIC_BONDING_CURVE_ADDRESS=0xALIVE00000000000000000000000000CURVE001
NEXT_PUBLIC_REGISTRY_ADDRESS=0xALIVE0000000000000000000000000REGISTRY01
NEXT_PUBLIC_BATTLE_ARENA_ADDRESS=0xALIVE000000000000000000000000BATTLE001
NEXT_PUBLIC_FEE_SPLITTER_ADDRESS=0xALIVE00000000000000000000000FEESPLIT01

# WalletConnect Project ID (get one at https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# X Layer RPC (optional, defaults built-in)
NEXT_PUBLIC_XLAYER_RPC_URL=https://rpc.xlayer.tech
