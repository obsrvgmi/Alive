# ==============================================
# ALIVE Backend - Environment Configuration
# ==============================================

# Database (PostgreSQL)
# Leave unset + USE_MOCK_DB=true for development without PostgreSQL
DATABASE_URL=postgresql://localhost:5432/alive

# Use in-memory mock database (no PostgreSQL needed)
# Set to "true" for quick local development
USE_MOCK_DB=true

# Redis (for caching & pub/sub)
# Optional - not required for development
REDIS_URL=redis://localhost:6379

# API Keys
# OpenAI - optional, falls back to deterministic generation
OPENAI_API_KEY=

# Internal API key for service-to-service auth
INTERNAL_API_KEY=dev-internal-key

# X Layer RPC
XLAYER_RPC_URL=https://rpc.xlayer.tech

# Contract Addresses (set after deployment)
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
BONDING_CURVE_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
BATTLE_ARENA_ADDRESS=0x0000000000000000000000000000000000000000

# Server
PORT=3001
NODE_ENV=development
