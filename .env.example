# ALIVE Frontend Environment Variables

# API Backend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# Contract Addresses (set after deployment)
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BONDING_CURVE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BATTLE_ARENA_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FEE_SPLITTER_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect Project ID (get one at https://cloud.walletconnect.com/)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# X Layer RPC (optional, defaults built-in)
NEXT_PUBLIC_XLAYER_RPC_URL=https://rpc.xlayer.tech
